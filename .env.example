# diretor.ai — variáveis de ambiente
# NUNCA commitar este arquivo com valores reais
# Configure as variáveis no painel da Vercel (Settings > Environment Variables)

# IA — Anthropic Claude
ANTHROPIC_API_KEY=coloque_sua_chave_anthropic_aqui

# IA — OpenAI GPT
OPENAI_API_KEY=coloque_sua_chave_openai_aqui

# Provedor padrão: anthropic | openai | fallback
AI_PROVIDER=anthropic
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENAI_MODEL=gpt-4.1

# Admin
ADMIN_PASSWORD=troque_esta_senha_antes_de_ir_para_producao

# Pagamentos — Stripe
STRIPE_SECRET_KEY=coloque_sua_chave_stripe_aqui
STRIPE_WEBHOOK_SECRET=coloque_seu_webhook_secret_aqui

# Pagamentos — Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=coloque_seu_token_mercadopago_aqui

# Canais de comunicação (integrações futuras — não usar no MVP)
TELEGRAM_BOT_TOKEN=coloque_o_token_futuro_aqui
WHATSAPP_BUSINESS_TOKEN=coloque_o_token_futuro_aqui
WHATSAPP_PHONE_NUMBER_ID=coloque_o_id_futuro_aqui

# Mapas — Google Maps Platform (integrações futuras — não usar no MVP sem backend proxy)
# IMPORTANTE: nunca expor estas chaves diretamente no frontend
# Todas as chamadas de mapa devem passar pelo backend (api/territory.js ou api/maps.js)
GOOGLE_MAPS_API_KEY=coloque_a_chave_futura_aqui
GOOGLE_PLACES_API_KEY=coloque_a_chave_places_futura_aqui
GOOGLE_GEOCODING_API_KEY=coloque_a_chave_geocoding_futura_aqui
GOOGLE_ROUTES_API_KEY=coloque_a_chave_routes_futura_aqui

# Mapas — Mapbox (integração futura)
MAPBOX_TOKEN=coloque_o_token_futuro_aqui

# Banco de dados (Supabase — futuro)
SUPABASE_URL=coloque_a_url_futura_aqui
SUPABASE_ANON_KEY=coloque_a_chave_futura_aqui
SUPABASE_SERVICE_ROLE_KEY=coloque_a_chave_service_role_futura_aqui
